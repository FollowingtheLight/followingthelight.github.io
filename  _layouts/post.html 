---
layout: post
---

<article>

<div>{{ content }}</div>

{% if page.categories.size > 0 %}
<p>分类：
{% for c in page.categories %}
{{ c }}
{% endfor %}
</p>
{% endif %}

<button onclick="var u=new SpeechSynthesisUtterance(document.body.innerText);u.lang='zh-CN';speechSynthesis.speak(u)">🔊 朗读</button>

</article>

<style>
  /* 1. 强制拉大所有段落的下间距 */
  article p {
    margin-bottom: 25px !important; 
    line-height: 1.8 !important;
  }

  /* 2. 针对作者名（通常是 strong, b, div 或 h3）强制加下间距 */
  article strong, 
  article b, 
  article div[style], 
  article h1, 
  article h2, 
  article h3 {
    margin-bottom: 20px !important;
    display: block !important; /* 确保它独占一行并产生间距 */
  }

  /* 3. 防止第一段被主题特殊处理（很多主题会把第一个 p 的 margin-top 设为 0） */
  article p:first-of-type {
    margin-top: 20px !important; 
  }
</style>
