layout: default

<article>
  {% if page.categories.size > 0 %}
  <p class="post-category">
    分类：
    {% for c in page.categories %}
      <a href="{{ site.baseurl }}/{{ c | slugify }}.html">{{ c }}</a>
    {% endfor %}
  </p>
  {% endif %}

  <div>{{ content }}</div>
</article>

<style>
  article p {
    margin-bottom: 25px !important; 
    line-height: 1.8 !important;
  }
  article strong, 
  article b, 
  article div[style], 
  article h1, 
  article h2, 
  article h3 {
    margin-bottom: 20px !important;
  }
  article p:first-of-type {
    margin-top: 20px !important; 
  }
  article ul,
  article ol {
    margin: 16px 0 24px 2em;
    line-height: 1.7;
  }
  article blockquote {
    border-left: 4px #666 solid;
    padding-left: 16px;
    margin: 20px 0;
    color: #555;
  }
  article pre {
    padding: 12px 16px;
    background: #f6f6f6;
    border-radius: 6px;
    overflow-x: auto;
    margin: 20px 0;
  }
  article audio {
    width: 100%;
    margin: 20px 0;
  }
  .post-category {
    margin-top: 30px;
  }
  .post-category a {
    display: inline-block;
    padding: 3px 10px;
    margin: 0 6px;
    background: #f0f0f0;
    color: #333;
    text-decoration: none;
    border-radius: 4px;
  }
  .post-category a:hover {
    background: #333;
    color: #fff;
  }
</style>
